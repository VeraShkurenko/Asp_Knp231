@model AspKnP231.Models.Home.DerivedKeyFormModel

@{
    ViewData["Title"] = "Derived Key";
}

<div class="text-center">
    <h1 class="display-4"><i class="bi bi-shield-lock"></i> Обчислення Derived Key</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <form asp-action="CalculateDerivedKey" method="post" class="border p-4 shadow-sm rounded bg-light">
            <div class="mb-3">
                <label class="form-label">Пароль</label>
                <input type="text" name="Password" value="@Model.Password" class="form-control" placeholder="Введіть пароль" />
                <span class="text-danger">@Html.ValidationMessage("Password")</span>
            </div>

            <div class="mb-3">
                <label class="form-label">Сіль</label>
                <div class="input-group">
                    <input type="text" id="saltInput" name="Salt" value="@Model.Salt" class="form-control" placeholder="Введіть сіль" @(Model.AutoSalt ? "readonly" : "") />
                </div>
                <span class="text-danger">@Html.ValidationMessage("Salt")</span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="AutoSalt" value="true" id="autoSaltCheck" @(Model.AutoSalt ? "checked" : "") onchange="document.getElementById('saltInput').readOnly = this.checked">
                <label class="form-check-label" for="autoSaltCheck">
                    Автоматична генерація солі
                </label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Обчислити</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.DerivedKey))
        {
            <div class="mt-4 alert alert-success">
                <h5>Результат:</h5>
                <p><strong>Сіль:</strong> @Model.Salt</p>
                <p><strong>DK:</strong> <code class="text-break">@Model.DerivedKey</code></p>
            </div>
        }
    </div>
</div>
